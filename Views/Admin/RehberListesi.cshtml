@model List<ds3.Models.rehber>
@{
    ViewData["Title"] = "Mevcut Rehberler";
    Layout = "_AdminLayout";
}

<div style="background: #111; color: #fff; padding: 30px; border-radius: 8px; margin: 40px; border: 1px solid #333;">
    <div
        style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #ffc107; padding-bottom: 10px;">
        <h2 style="color: #ffc107;">📜 Tüm Rehberler</h2>
        <a href="/Admin/RehberEkle"
           style="background:#ffc107; color:#000; padding:10px 15px; text-decoration:none; font-weight:bold; border-radius: 4px;">+
            Yeni Rehber</a>
        </div>

        <table style="width: 100%; margin-top: 20px; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="border-bottom: 1px solid #444; color: #ffc107;">
                    <th style="padding: 12px; width: 60px;">#</th>
                    <th style="padding: 12px;">Görsel</th>
                    <th style="padding: 12px;">Başlık</th>
                    <th style="padding: 12px;">Yazar</th>
                    <th style="padding: 12px;">Tarih</th>
                    <th style="padding: 12px; text-align: center;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid #222;" onmouseover="this.style.backgroundColor='#1a1a1a'"
                        onmouseout="this.style.backgroundColor='transparent'">

                        <td style="padding: 12px; font-weight: bold; color: #ffc107; font-family: 'Cinzel', serif;">
                            #@item.Id
                        </td>

                        <td style="padding: 12px;">
                            <img src="/images/@item.ResimUrl"
                                 style="width: 60px; height: 40px; object-fit: cover; border: 1px solid #333; border-radius: 4px;" />
                        </td>
                        <td style="padding: 12px; font-weight: bold;">@item.Baslik</td>
                        <td style="padding: 12px;">@item.Yazar</td>
                        <td style="padding: 12px;">@item.Tarih.ToString("dd MMMM yyyy")</td>

                        <td style="padding: 12px; text-align: center; white-space: nowrap;">

                            <a href="/Admin/RehberGuncelle?id=@item.Id"
                               style="background: #e67e22; color: #fff; padding: 6px 12px; text-decoration: none; font-weight: bold; border-radius: 4px; margin-right: 5px; font-size: 13px; display: inline-block;"
                               title="Yazıtı Düzenle">
                                ✍️ Güncelle
                            </a>

                            <a href="/Admin/RehberSil?id=@item.Id"
                               style="background: #c0392b; color: #fff; padding: 6px 12px; text-decoration: none; font-weight: bold; border-radius: 4px; font-size: 13px; display: inline-block;"
                               title="Yazıtı Tamamen Sil"
                               onclick="return confirm('Bu efsane rehberi ebediyen silmek istediğine emin misin?')">
                                🗑️ Sil
                            </a>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>