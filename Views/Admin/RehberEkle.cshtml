@model ds3.Models.RehberViewModel

@{
    ViewData["Title"] = "Yeni Rehber Ekle";
    Layout = "_AdminLayout";
}

<style>
    .souls-container {
        background: radial-gradient(circle at top, #1a1510 0%, #0a0a0a 100%);
        color: #eee;
        padding: 40px;
        border-radius: 4px;
        max-width: 650px;
        margin: 50px auto;
        border: 1px solid #3a2f1d;
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.8), 0 0 15px rgba(197, 160, 89, 0.05);
        font-family: 'Cinzel', 'Georgia', serif;
    }

    .souls-title {
        color: #c5a059;
        font-size: 1.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        border-bottom: 1px solid #3a2f1d;
        padding-bottom: 15px;
        margin-bottom: 30px;
        text-shadow: 0 0 10px rgba(197, 160, 89, 0.3);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .souls-form-group {
        margin-bottom: 25px;
        position: relative;
    }

    .souls-label {
        display: block;
        margin-bottom: 8px;
        color: #a3937b;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .souls-input,
    .souls-textarea {
        width: 100%;
        padding: 12px 15px;
        background: #121212;
        border: 1px solid #2a2216;
        color: #fff;
        font-size: 0.95rem;
        border-radius: 2px;
        transition: all 0.4s ease;
        box-shadow: inset 0 0 8px rgba(0, 0, 0, 0.6);
    }

    .souls-input:focus,
    .souls-textarea:focus {
        outline: none;
        border-color: #c5a059;
        box-shadow: 0 0 12px rgba(197, 160, 89, 0.25), inset 0 0 5px rgba(0, 0, 0, 0.8);
        background: #161616;
    }

    .souls-input[type="file"] {
        padding: 10px;
        background: #15120e;
        border: 1px dashed #4a3b25;
        color: #8c7b65;
    }

    .souls-input[type="file"]:hover {
        border-color: #c5a059;
        color: #eee;
    }

    .souls-error {
        color: #ff4444;
        font-size: 0.8rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: block;
        margin-top: 6px;
        text-shadow: 0 0 5px rgba(255, 68, 68, 0.2);
    }

    .bonfire-btn {
        background: linear-gradient(135deg, #a47a32 0%, #684a1a 100%);
        color: #000;
        padding: 15px 25px;
        border: 1px solid #c5a059;
        cursor: pointer;
        font-weight: bold;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        width: 100%;
        margin-top: 15px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    }

    .bonfire-btn:hover {
        background: linear-gradient(135deg, #ffb33a 0%, #b37d29 100%);
        box-shadow: 0 0 20px rgba(255, 153, 0, 0.4);
        text-shadow: 0 0 2px #fff;
        transform: translateY(-1px);
    }
</style>

<div class="souls-container">
    <h2 class="souls-title">
        <span>🔥</span> Yeni Kadim Rehber Mühürle
    </h2>

    <form asp-action="RehberEkle" asp-controller="Admin" method="post" enctype="multipart/form-data"
          style="margin-top: 20px;">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="souls-form-group">
            <label class="souls-label">Rehber Başlığı</label>
            <input asp-for="Baslik" class="souls-input" placeholder="Örn: Lothric Şatosu Gizemleri"
                   autocomplete="off" />
            <span asp-validation-for="Baslik" class="souls-error"></span>
        </div>

        <div class="souls-form-group">
            <label class="souls-label">Kısa Özet (Şenlik Ateşinde Görünecek)</label>
            <input asp-for="Ozet" class="souls-input"
                   placeholder="Karanlık yollara rehberlik edecek kısa bir özet metni..." autocomplete="off" />
            <span asp-validation-for="Ozet" class="souls-error"></span>
        </div>

        <div class="souls-form-group">
            <label class="souls-label">Kadim Parşömen Görseli (Resim)</label>
            <div class="souls-file-wrapper">
                <input asp-for="ResimDosyasi" type="file" accept="image/*" class="souls-input" />
            </div>
            <span asp-validation-for="ResimDosyasi" class="souls-error"></span>
        </div>

        <div class="souls-form-group">
            <label class="souls-label">Rehber Detay İçeriği (Yazıt)</label>
            <textarea asp-for="Icerik" rows="7" class="souls-textarea"
                      placeholder="Bölge taktikleri, boss zayıflıkları ve gizli geçitlerin detayları..."></textarea>
            <span asp-validation-for="Icerik" class="souls-error"></span>
        </div>

        <div class="souls-form-group">
            <label class="souls-label">Yazıtı Mühürleyen (Yazar)</label>
            <input asp-for="Yazar" class="souls-input" />
            <span asp-validation-for="Yazar" class="souls-error"></span>
        </div>

        <div class="souls-form-group">
            <label class="souls-label">Detaylı Uzun İçerik</label>
            <textarea asp-for="UzunIcerik" rows="8" class="souls-textarea"
                      placeholder="Rehberin tüm derinliğini, lore detaylarını buraya yaz..."></textarea>
            <span asp-validation-for="UzunIcerik" class="souls-error"></span>
        </div>

        <div class="souls-form-group">
            <label class="souls-label">Taktik Videosu Linki (Youtube)</label>
            <input asp-for="VideoUrl" class="souls-input" placeholder="https://youtube.com/..." />
            <span asp-validation-for="VideoUrl" class="souls-error"></span>
        </div>

        <button type="submit" class="bonfire-btn">
            Rehberi Bonfire'a Mühürle →
        </button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}