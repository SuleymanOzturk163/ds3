@model List<ds3.Models.Boss>

@{
    ViewData["Title"] = "Boss Listesi";
    Layout = "_AdminLayout";
}

<div class="container-fluid" style="padding: 30px;">
    <div class="row">
        <div class="col-10 mx-auto">

            <div class="card"
                 style="background-color: #1a1a1a; color: #e0e0e0; border: 2px solid #3e3a36; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">

                <div class="card-header"
                     style="background-color: #262626; border-bottom: 2px solid #3e3a36; padding: 20px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h2 class="m-0"
                            style="color: #d1a153; font-family: 'Georgia', serif; text-shadow: 1px 1px 2px #000;">
                            ⚔️ Canavar Düzenleme & Listeleme Paneli
                        </h2>
                        <small style="color: #8c8c8c;">Sistemde kayıtlı olan tüm haşmetli bosslar</small>
                    </div>
                    <a href="/Admin/BossEkle" class="btn"
                       style="background-color: #d1a153; color: #000; font-weight: bold; border-radius: 4px; padding: 10px 20px; transition: all 0.3s;">
                        + Yeni Boss Ekle
                    </a>
                </div>

                <div class="card-body" style="padding: 20px;">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover m-0"
                               style="background-color: #1a1a1a; color: #e0e0e0; border-color: #3e3a36;">
                            <thead>
                                <tr style="color: #d1a153; border-bottom: 2px solid #3e3a36;">
                                    <th style="padding: 15px;">#</th>
                                    <th style="padding: 15px;">Görsel</th>
                                    <th style="padding: 15px;">Boss Adı</th>
                                    <th style="padding: 15px;">Bulunduğu Mekan</th>
                                    <th style="padding: 15px;">Can (HP)</th>
                                    <th style="padding: 15px;">Durum</th>
                                    <th style="padding: 15px; text-align: center;">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr style="border-bottom: 1px solid #322d28; vertical-align: middle;">
                                        <td style="padding: 15px; font-weight: bold; color: #d1a153;">#@item.Id</td>
                                        <td style="padding: 15px;">
                                            <img src="/images/@item.ImageUrl"
                                                 style="width: 70px; height: 45px; object-fit: cover; border: 1px solid #3e3a36; border-radius: 4px;" />
                                        </td>
                                        <td style="padding: 15px; font-weight: bold;">@item.Name</td>
                                        <td style="padding: 15px; color: #aaa;">@item.Location</td>
                                        <td style="padding: 15px; color: #e67e22; font-weight: bold;">❤️ @item.Health</td>
                                        <td style="padding: 15px;">
                                            @if (item.IsRequired)
                                            {
                                                <span class="badge"
                                                      style="background-color: #7f0000; color: #fff; padding: 6px 10px; border: 1px solid #ff0000;">💀
                                                    ZORUNLU</span>
                                                }
                                            else
                                                {
                                                    <span class="badge"
                                                          style="background-color: #1e3c72; color: #fff; padding: 6px 10px; border: 1px solid #2a5298;">🛡️
                                                        OPSİYONEL</span>
                                                    }
                                                </td>
                                                <td style="padding: 15px; text-align: center; white-space: nowrap;">
                                                    <a href="/Admin/BossGuncelle?id=@item.Id" class="btn btn-sm btn-warning"
                                                       style="background-color: #e67e22; border: none; color: #fff; font-weight: bold; padding: 6px 15px; margin-right: 5px;">
                                                        ✍️ Güncelle
                                                    </a>
                                                    <a href="/Admin/BossSil?id=@item.Id" class="btn btn-sm btn-danger"
                                                       style="background-color: #c0392b; border: none; color: #fff; font-weight: bold; padding: 6px 15px;"
                                                       onclick="return confirm('Bu boss\'u ebediyen silmek istediğine emin misin Ashen One?')">
                                                        🗑️ Sil
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>