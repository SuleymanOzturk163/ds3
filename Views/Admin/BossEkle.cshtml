@model ds3.Models.BossViewModel

@{
    ViewData["Title"] = "Boss Ekle";
    Layout = "_AdminLayout";
}

<div class="container" style="margin-top: 40px; margin-bottom: 40px;">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card" style="background-color: #1a1a1a; color: #e0e0e0; border: 2px solid #3e3a36; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">

                <div class="card-header" style="background-color: #262626; border-bottom: 2px solid #3e3a36; padding: 20px;">
                    <h2 class="m-0" style="color: #d1a153; font-family: 'Georgia', serif; text-shadow: 1px 1px 2px #000;">
                        ⚔️ Yeni Canavar Ekleme Paneli
                    </h2>
                    <small style="color: #8c8c8c;">Ruhlar günlüğüne taptaze bir canavar mühürle</small>
                </div>

                <form action="/Admin/BossEkle" method="post" enctype="multipart/form-data">

                    @Html.AntiForgeryToken()

                    <div class="card-body" style="padding: 30px;">
                        
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label" style="color: #d1a153; font-weight: bold;">Boss Adı</label>
                                <input asp-for="Name" class="form-control" style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;" placeholder="Örn: Iudex Gundyr" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label" style="color: #d1a153; font-weight: bold;">Bulunduğu Kadim Mekan</label>
                                <input asp-for="Location" class="form-control" style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;" placeholder="Örn: Giriş Bölgesi - Mezarlık" />
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label" style="color: #d1a153; font-weight: bold;">Can Gücü (HP)</label>
                                        <input asp-for="Health" type="number" min="0" class=" form-control"
                                               style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;"
                                               placeholder="Örn: 3,755" />
                                <span asp-validation-for="Health" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label" style="color: #d1a153; font-weight: bold;">Ölünce Vereceği Ruh (Souls)</label>
                                            <input asp-for="Souls" type="number" min="0" class="form-control"
                                                   style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;"
                                                   placeholder="Örn: 3,000" />
                                <span asp-validation-for="Souls" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label" style="color: #d1a153; font-weight: bold;">Kader Durumu (İlerleme İçin Şart mı?)</label>
                            <select asp-for="IsRequired" class="form-control" style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;">
                                <option value="true">💀 Hikaye İçin Zorunlu Boss</option>
                                <option value="false">🛡️ İsteğe Bağlı (Gizli/Opsiyonel) Boss</option>
                            </select>
                            <span asp-validation-for="IsRequired" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label" style="color: #d1a153; font-weight: bold;">Canavarın Zayıflıkları</label>
                            <input asp-for="Weaknesses" class="form-control" style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;" placeholder="Örn: Ateş, Yıldırım, Savuşturma" />
                            <span asp-validation-for="Weaknesses" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label" style="color: #d1a153; font-weight: bold;">Detaylı Taktik Video Linki (Youtube)</label>
                            <input asp-for="VideoUrl" class="form-control" style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;" placeholder="Örn: https://www.youtube.com/watch?v=..." />
                            <span asp-validation-for="VideoUrl" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label" style="color: #d1a153; font-weight: bold;">Haşmetli Boss Parşömeni Görseli</label>
                            <input asp-for="ImageUrl" type="file" class="form-control" accept="image/*" style="background-color: #2b2b2b; color: #fff; border: 1px solid #444; padding: 10px;" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                    </div> <div class="card-footer" style="background-color: #262626; border-top: 2px solid #3e3a36; padding: 20px; text-align: right;">
                        <a href="/Admin/BossListesi" class="btn btn-secondary" style="padding: 10px 25px; margin-right: 10px; border-radius: 4px; font-weight: bold;">
                            ❌ İptal Et
                        </a>
                        <button type="submit" class="btn" style="background-color: #d1a153; color: #000; padding: 10px 30px; border-radius: 4px; font-weight: bold; transition: all 0.3s;">
                            🔥 Boss Ruhunu Mühürle (Kaydet)
                        </button>
                    </div>

                </form>
            </div> </div> </div> </div>
             @section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}