@model List<ds3.Models.Uye>

@{
    ViewData["Title"] = "Üye Listesi";
    Layout = "_AdminLayout";
}

<div class="container-fluid" style="padding: 30px;">
    <div class="row">
        <div class="col-10 mx-auto">

            <div class="card"
                 style="background-color: #1a1a1a; color: #e0e0e0; border: 2px solid #3e3a36; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">

                <div class="card-header"
                     style="background-color: #262626; border-bottom: 2px solid #3e3a36; padding: 20px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h2 class="m-0"
                            style="color: #d1a153; font-family: 'Georgia', serif; text-shadow: 1px 1px 2px #000;">
                            👥 Ashen One (Üye) Listesi
                        </h2>
                        <small style="color: #8c8c8c;">Kayıtlı olan tüm kullanıcıların listesi</small>
                    </div>
                </div>

                <div class="card-body" style="padding: 20px;">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover m-0"
                               style="background-color: #1a1a1a; color: #e0e0e0; border-color: #3e3a36;">
                            <thead>
                                <tr style="color: #d1a153; border-bottom: 2px solid #3e3a36;">
                                    <th style="padding: 15px;">#</th>
                                    <th style="padding: 15px;">Kullanıcı Adı</th>
                                    <th style="padding: 15px;">Email</th>
                                    <th style="padding: 15px; text-align: center;">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var uye in Model)
                                {
                                    <tr style="border-bottom: 1px solid #322d28; vertical-align: middle;">
                                        <td style="padding: 15px; font-weight: bold; color: #d1a153;">@uye.Id</td>
                                        <td style="padding: 15px; font-weight: bold;">@uye.KullaniciAdi</td>
                                        <td style="padding: 15px; color: #aaa;">@uye.Email</td>
                                        <td style="padding: 15px; text-align: center;">
                                            <a href="/Admin/UyeSil?id=@uye.Id" class="btn btn-sm btn-danger"
                                               style="background-color: #c0392b; border: none; color: #fff; font-weight: bold; padding: 6px 15px;"
                                               onclick="return confirm('Bu kullanıcıyı ebediyen silmek istediğine emin misin?')">
                                                🗑️ Sil
                                            </a>
                                            <a href="/Admin/UyeGuncelle?id=@uye.Id" class="btn btn-sm btn-warning">✍️
                                                Düzenle</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>