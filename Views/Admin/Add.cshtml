@{
    ViewData["Title"] = "Yeni Lokasyon Keşfet";
    Layout = "_AdminLayout";
}

@model LocationViewModel

<style>
    
    .ds-page-title h1 {
        font-family: 'Cinzel', serif;
        color: #c5a059;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-shadow: 0 0 10px rgba(197, 160, 89, 0.2);
    }

    .ds-page-title p {
        color: #888;
        font-style: italic;
        font-size: 0.9rem;
    }

    .ds-form-card {
        background: linear-gradient(135deg, #151515 0%, #111111 100%) !important;
        border: 1px solid rgba(140, 115, 64, 0.3) !important;
        border-radius: 4px;
        padding: 2.5rem;
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.8), 0 10px 25px rgba(0, 0, 0, 0.5);
        position: relative;
    }

    .ds-form-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 6px;
        height: 6px;
        border-top: 2px solid #c5a059;
        border-left: 2px solid #c5a059;
    }

    .ds-label {
        font-family: 'Cinzel', serif;
        color: #8c7340;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
        display: block;
        text-transform: uppercase;
    }

    .ds-input,
    .ds-textarea,
    .ds-select {
        background-color: #1a1a1a !important;
        border: 1px solid rgba(140, 115, 64, 0.3) !important;
        color: #e0e0e0 !important;
        border-radius: 2px !important;
        padding: 0.75rem 1rem;
        width: 100%;
        transition: all 0.3s ease-in-out;
    }

    .ds-input:focus,
    .ds-textarea:focus,
    .ds-select:focus {
        outline: none !important;
        border-color: #c5a059 !important;
        box-shadow: 0 0 10px rgba(197, 160, 89, 0.25) !important;
    }

    .ds-input[type="file"] {
        padding: 0.6rem;
        font-size: 0.85rem;
        color: #888;
    }

    .btn-ds-save {
        background-color: #1f1a15 !important;
        border: 1px solid #8c7340 !important;
        color: #c5a059 !important;
        font-family: 'Cinzel', serif;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.75rem 2rem;
        transition: all 0.4s ease;
        border-radius: 2px;
        cursor: pointer;
    }

    .btn-ds-save:hover {
        background-color: #c5a059 !important;
        color: #111 !important;
        box-shadow: 0 0 15px rgba(197, 160, 89, 0.4);
        font-weight: bold;
    }

    .btn-ds-cancel {
        background-color: transparent !important;
        border: 1px solid rgba(224, 224, 224, 0.2) !important;
        color: #aaa !important;
        font-family: 'Cinzel', serif;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.75rem 2rem;
        transition: all 0.4s ease;
        border-radius: 2px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-ds-cancel:hover {
        border-color: #e0e0e0 !important;
        color: #fff !important;
        background-color: rgba(255, 255, 255, 0.02) !important;
    }

    .ds-alert-danger {
        background-color: #241212 !important;
        border: 1px solid #660000 !important;
        color: #ff4d4d !important;
        border-radius: 2px !important;
    }
</style>

<div class="admin-page">

    <div class="ds-page-title mb-4">
        <h1>Yeni Lokasyon Keşfet</h1>
        <p>Lothric krallığının haritasına yeni bir kadim bölgeyi mühürle.</p>
    </div>

    <div class="ds-form-card">

        <form asp-action="Add" method="post" enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert ds-alert-danger mb-4"></div>

            <div class="row g-4">

                <div class="col-md-6">
                    <label asp-for="Title" class="ds-label">Lokasyon Adı</label>
                    <input asp-for="Title" type="text" class="ds-input"
                           placeholder="Örn: Firelink Shrine, Cemeteries of Ash" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="InfoSubtitle" class="ds-label">Lokasyon Alt Başlığı</label>
                    <input asp-for="InfoSubtitle" type="text" class="ds-input"
                           placeholder="Örn: Küllerin ve Sönmeyen Ateşin İstirahatgahı" />
                    <span asp-validation-for="InfoSubtitle" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Category" class="ds-label">Lokasyon Kategorisi</label>
                    <select asp-for="Category" class="ds-select">
                        <option value="false">Safe Zone (Güvenli Bölge / Kamp Ateşi)</option>
                        <option value="true">Ölümcül Bölge / PVP (Boss & Tehlike Var)</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ImageUrl" class="ds-label">Lokasyon Manzarası (Görsel)</label>
                    <input asp-for="ImageUrl" type="file" class="ds-input" />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="ds-label">Lokasyon Açıklaması (Kitabe)</label>
                    <textarea asp-for="Description" rows="6" class="ds-textarea"
                              placeholder="Küllerin bu bölgeye ayak bastığında okuyacağı o kadim kitabe yazısını, bölgenin tarihini ve lore bilgisini buraya kazı..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

            </div>

            <div class="d-flex justify-content-between mt-5">

                <a href="/Admin/Lokasyon" class="btn-ds-cancel">
                    Keşiften Vazgeç
                </a>

                <button type="submit" class="btn-ds-save">
                    Mührü Kazı (Kaydet)
                </button>

            </div>

        </form>

    </div>

</div>

<partial name="_ValidationScriptsPartial" />