    <div id="sidebar-cart">
        <div id="cart-header">
            <h2>Sepetiniz</h2>
            <button id="close-cart">&times;</button>
        </div>
        <div id="cart-items">
            <p style="text-align: center; color: #999">Sepetiniz şu anda boş.</p>
        </div>
        <div id="cart-footer">
            <div>
                <span>Toplam Tutar:</span>
                <span id="cart-total">0.00 TL</span>
            </div>
            <button class="checkout-btn">Sepeti Onayla</button>
        </div>
    </div>


    @section Scripts {
        <script src="~/js/alisveris.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
            document.body.style.setProperty("background-color", "#ff9999", "important");
            document.body.style.setProperty("background-image", "none", "important");
            });
        </script>
    }