@model List<ds3.Models.Boss>

@{
    ViewData["Title"] = "Boss Rehberi";
}

@section SayfaStyle {
    <link rel="stylesheet" href="~/BossRehberi.css" />
}

<header class="genelbaslik">
    <div class="baslik">
        <h1>BOSS REHBERİ SAYFASI</h1>
        <p>Lothric'in en zorlu düşmanlarına karşı stratejiler</p>
    </div>
</header>

<div class="not">
    <div class="souls-not">
        <span class="ünlemicon">⚠️</span>
        <p><strong>Ashen One!</strong> Bu rehber Lothric'in en karanlık sırlarını açığa çıkarır. Unutma: Sayfadaki tüm
            istatistikler standart Yeni Oyun (NG) verileridir ve Bossların zayıflıkları, maksimum hasar potansiyeline
            göre listelenmiştir. Her zaman iki faza hazırlıklı ol!</p>
            <h6>— Şenlik Ateşi Muhafızı'nın Öğüdü</h6>
        </div>
    </div>

    <hr class="cizgim">

    <div class="Bossİcerik">
        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/ludexboss.webp" alt="Iudex Gundyr" class="boss-resim">
                <span class="bos-statlari zorunlu-stat">Zorunlu</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Iudex Gundyr</h2>
                <p class="boss-konum">Giriş Bölgesi - Mezarlık</p>
                <div class="boss-istatistik">
                    <p>Can: <span class="statlar">3,755</span></p>
                    <p>Ruh: <span class="statlar">3,000</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Ateş</span></li>
                        <li><span class="zayifitem">Yıldırım (2. Faz)</span></li>
                        <li><span class="zayifitem">Savuşturma</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=575YkIJSk24" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/vordtboss.jpg" alt="Boreal Vadisi Vordt" class="boss-resim">
                <span class="bos-statlari zorunlu-stat">Zorunlu</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Boreal Vadisi Vordt</h2>
                <p class="boss-konum">Yüksek Duvar - Lothric</p>
                <div class="boss-istatistik">
                    <p>Can: <span class="statlar">1,300</span></p>
                    <p>Ruh: <span class="statlar">3,000</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Karanlık</span></li>
                        <li><span class="zayifitem">Kanama</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=9qKEPxPcapg" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/abbyswatcherboss.jpg" alt="Abyss Watchers" class="boss-resim">
                <span class="bos-statlari zorunlu-stat">Zorunlu</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Abyss Watchers</h2>
                <p class="boss-konum">Farron'un Gözcüleri Kalesi</p>
                <div class="boss-istatistik">
                    <p>Can: <span class="statlar">3,495</span></p>
                    <p>Ruh: <span class="statlar">18,000</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Kanama</span></li>
                        <li><span class="zayifitem">Savuşturma (2. Faz Hariç)</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=vv_qryPwmig" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/Pontiffsulyhvanboss.jpg" alt="Pontiff Sulyvahn" class="boss-resim">
                <span class="bos-statlari zorunlu-stat">Zorunlu</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Pontiff Sulyvahn</h2>
                <p class="boss-konum">Irithyll Tapınağı</p>
                <div class="boss-istatistik">
                    <p>Can: <span class="statlar">5,078</span></p>
                    <p>Ruh: <span class="statlar">28,000</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Savuşturma</span></li>
                        <li><span class="zayifitem">Yıldırım</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=fo-Sc7ciEgk" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/dancerboss.jpg" alt="Dancer" class="boss-resim">
                <span class="bos-statlari zorunlu-stat">Zorunlu</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Dancer</h2>
                <p class="boss-konum">Vordt Odası Üstü - Lothric Kalesi</p>
                <div class="boss-istatistik">
                    <p>Can: <span class="statlar">4,912</span></p>
                    <p>Ruh: <span class="statlar">60,000</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Karanlık</span></li>
                        <li><span class="zayifitem">Kanama</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=jZ21JRZKSK4" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/dragonslayerboss.avif" alt="Dragon Slayer" class="boss-resim">
                <span class="bos-statlari zorunlu-stat">Zorunlu</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Dragon Slayer</h2>
                <p class="boss-konum">Büyük Arşiv Kapısı - Lothric Kalesi</p>
                <div class="boss-istatistik">
                    <p>Can: <span class="statlar">5,820</span></p>
                    <p>Ruh: <span class="statlar">70,000</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Buz (Frostbite)</span></li>
                        <li><span class="zayifitem">Büyü Hasarı</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=5sk-e0uokOI" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/championgundyboss.webp" alt="Champion Gundyr" class="boss-resim">
                <span class="bos-statlari istegebaglistat">İsteğe Bağlı</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Champion Gundyr</h2>
                <p class="boss-konum">Gizli Mezar - Gündüz Yangını</p>
                <div class="boss-istatistik">
                    <p>Can: <span class="statlar">4,960</span></p>
                    <p>Ruh: <span class="statlar">60,000</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Yıldırım</span></li>
                        <li><span class="zayifitem">Savuşturma</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=hFcKdDvKyDw" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        <div class="bosskart">
            <div class="bossresimkutusu">
                <img src="~/images/namelesskingboss.jpg" alt="Nameless King" class="boss-resim"
                     style="object-fit: cover; width: 100%; height: 100%;">
                <span class="bos-statlari istegebaglistat">İsteğe Bağlı</span>
            </div>
            <div class="boss-bilgi">
                <h2 class="boss-yazi">Nameless King</h2>
                <p class="boss-konum">Yıldırım Tepesi - Lothric</p>
                <div class="boss-istatistik">
                    <p>Can (Kraliyet Kuşu): <span class="statlar">3,889</span></p>
                    <p>Can (Kral): <span class="statlar">7,100</span></p>
                </div>
                <div class="boss-zayiflik">
                    <h3>Zayıflıklar</h3>
                    <ul>
                        <li><span class="zayifitem">Yıldırım (1. Faz Kuş)</span></li>
                        <li><span class="zayifitem">Ateş (Kral)</span></li>
                    </ul>
                </div>
                <a href="https://www.youtube.com/watch?v=SyFNPZN82kg" class="boss-link" target="_blank">Detaylı Video →</a>
            </div>
        </div>

        @if (Model != null)
        {
            foreach (var boss in Model)
            {
                <div class="bosskart">
                    <div class="bossresimkutusu">
                        <img src="/images/@boss.ImageUrl" alt="@boss.Name" class="boss-resim">

                        @if (boss.IsRequired)
                        {
                            <span class="bos-statlari zorunlu-stat">Zorunlu</span>
                        }
                        else
                        {
                            <span class="bos-statlari istegebaglistat">İsteğe Bağlı</span>
                        }
                    </div>
                    <div class="boss-bilgi">
                        <h2 class="boss-yazi">@boss.Name</h2>
                        <p class="boss-konum">@boss.Location</p>
                        <div class="boss-istatistik">
                            <p>Can: <span class="statlar">@boss.Health</span></p>
                            <p>Ruh: <span class="statlar">@boss.Souls</span></p>
                        </div>
                        <div class="boss-zayiflik">
                            <h3>Zayıflıklar</h3>
                            <ul>
                                @if (!string.IsNullOrEmpty(boss.Weaknesses))
                                {
                                    // Virgülle ayrılmış zayıflıkları söküp alt alta li elementlerine bölüyoruz kankam
                                    var dizi = boss.Weaknesses.Split(new[] { ',', '-' }, StringSplitOptions.RemoveEmptyEntries);
                                    foreach (var zayiflik in dizi)
                                    {
                                        <li><span class="zayifitem">@zayiflik.Trim()</span></li>
                                    }
                                }
                                else
                                {
                                    <li><span class="zayifitem">Bilinmiyor</span></li>
                                }
                            </ul>
                        </div>
                        <a href="@boss.VideoUrl" class="boss-link" target="_blank">Detaylı Video →</a>
                    </div>
                </div>
            }
        }
    </div>

    @section Scripts {
        <script src="~/js/loader.js"></script>
    }