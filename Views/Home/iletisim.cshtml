@{
    ViewData["Title"] = "Dark Souls 3 Wiki - İletişim";
}

@section SayfaStyle {
    <link rel="stylesheet" href="~/iletisim.css" />
}

<div class="containeri">
    <div class="basliki">
        <h1>Bize Ulaşın</h1>
    </div>

    <div class="iletisim">
        <div class="mesajformu">
            <h2>Mesajınızı Gönderin</h2>
            <form action="#" method="POST">
                <div class="form-grup">
                    <div class="form-dosya">
                        <label for="first-name">Adınız</label>
                        <input type="text" id="first-name" name="first-name" placeholder="Süleyman..." required />
                    </div>
                    <div class="form-dosya">
                        <label for="last-name">Soyadınız</label>
                        <input type="text" id="last-name" name="last-name" placeholder="Öztürk..." required />
                    </div>
                </div>

                <div class="form-grup">
                    <div class="form-dosya">
                        <label for="email">E-posta</label>
                        <input type="email" id="email" name="email" placeholder="SuleymanOzturk@gmail.com..."
                               required />
                    </div>
                    <div class="form-dosya">
                        <label for="mobile">Cep Telefonu</label>
                        <input type="text" id="mobile" name="mobile" placeholder="+90 5XX XXX XX XX..." />
                    </div>
                </div>

                <div class="ful-genislik">
                    <label for="message">Mesajınız</label>
                    <textarea id="message" name="message" placeholder="Mesajınızı buraya yazın..." required></textarea>
                </div>

                <button type="submit" class="gonderbuton">
                    Mesajınızı Gönderin
                </button>
            </form>
        </div>

        <div class="iletisiminfo">
            <h2>İletişim Bilgileri</h2>

            <div class="info-item">
                <i class="fa-solid fa-building"></i>
                <span>Girne, Dörtler sokağı, No:36 34852 Maltepe/İstanbul</span>
            </div>

            <div class="info-item">
                <i class="fas fa-map-marker-alt"></i>
                <span>Fındıklı Mahallesi, Limon Sk, İstanbul/Maltepe</span>
            </div>

            <div class="info-item">
                <i class="fas fa-envelope"></i>
                <span>SuleymanOzturk106@gmail.com</span>
            </div>

            <div class="info-item">
                <i class="fas fa-phone"></i>
                <span>+90 506 907 51 10</span>
            </div>

            <div class="sosyal">
                <a href="#"><i class="fab fa-facebook-f"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-linkedin-in"></i></a>
            </div>

            <div class="harita">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3013.8242488896593!2d29.14152777655455!3d40.94150532353724!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cac44101e9be75%3A0x6739b69b61ed124c!2sHandan%20Hayrettin%20Yelkikanat%20Mesleki%20ve%20Teknik%20Anadolu%20Lisesi!5e0!3m2!1str!2str!4v1715868000000!5m2!1str!2str"
                    width="100%" height="100%" style="border: 0;" allowfullscreen="" loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>
    </div>
</div>