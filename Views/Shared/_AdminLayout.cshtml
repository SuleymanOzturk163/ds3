<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Firelink Shrine - Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
    href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Lora:ital,wght@0,400;1,400&display=swap"
    rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    @await RenderSectionAsync("Scripts", required: false)

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <style>
            body {
                background-color: #111111 !important;
                color: #e0e0e0 !important;
                font-family: 'Lora', serif;
                overflow-x: hidden;
            }

            .ds-font,
            h2,
            h4,
            .menu a {
                font-family: 'Cinzel', serif;
                letter-spacing: 0.1em;
            }

            
            .admin-wrapper {
                display: flex;
                min-hight: 100vh;
                width: 100%;
            }

            
            .sidebar {
                width: 260px;
                min-height: 100vh;
                background-color: #151515;
                border-righ: 1px solid rgba(140, 115, 64, 0.3);
                display: flex;
                flex-direction: column;
                z-index: 10;
                box-shadow: 5px 0 15px rgba(0, 0, 0, 0.5);
            }

            
            .logo-area {
                padding: 2rem 1.5rem;
                border-bottom: 1px solid rgba(140, 115, 64, 0.15);
                text-align: center;
            }

            .logo-area h2 {
                color: #c5a059;
                font-weight: 700;
                font-size: 1.6rem;
                margin-bottom: 0.2rem;
                text-shadow: 0 0 10px rgba(197, 160, 89, 0.2);
            }

            .logo-area p {
                font-size: 0.75rem;
                color: #666;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                margin: 0;
                font-style: italic;
            }

            
            .menu {
                display: flex;
                flex-direction: column;
                padding: 1.5rem 0.75rem;
                gap: 0.5rem;
            }

            .menu a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 0.85rem 1rem;
                color: #aaa;
                text-decoration: none;
                font-size: 0.9rem;
                border-left: 3px solid transparent;
                transition: all 0.3s ease-in-out;
                border-radius: 0 4px 4px 0;
            }

            
            .menu a:hover {
                background-color: rgba(140, 115, 64, 0.08);
                color: #c5a059 !important;
                border-left-color: #8c7340;
                padding-left: 1.25rem;
            }

           
            .main-content {
                flex: 1;
                display: flex;
                flex-direction: column;
                background-color: #1a1a1a;
                min-height: 100vh;
            }

            
            .topbar {
                height: 70px;
                background-color: #151515;
                border-bottom: 1px solid rgba(140, 115, 64, 0.15);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 2rem;
            }

            .topbar h4 {
                color: #c5a059;
                margin: 0;
                font-size: 1.15rem;
                font-weight: 600;
            }

            .admin-user {
                display: flex;
                align-items: center;
                gap: 8px;
                color: #8c7340;
                font-size: 0.9rem;
                font-weight: bold;
            }

            .admin-user i {
                color: #8b0000;
                
            }

            
            .content-area {
                padding: 2.5rem;
                flex: 1;
            }

            
            ::-webkit-scrollbar {
                width: 6px;
            }

            ::-webkit-scrollbar-track {
                background: #111;
            }

            ::-webkit-scrollbar-thumb {
                background: #8c7340;
                border-radius: 2px;
            }

            ::-webkit-scrollbar-thumb:hover {
                background: #c5a059;
            }
    </style>

</head>

<body>

    <div class="admin-wrapper">

        <aside class="sidebar">

            <div class="logo-area">
                <h2>DARK SOULS</h2>
                <p>Ashen One Panel</p>
            </div>

            <nav class="menu">

                <a asp-controller="Admin" asp-action="Lokasyon">
                    <i class="fa-solid fa-shield-halved text-secondary"></i>
                    Lokasyonlar
                </a>

                <a asp-controller="Admin" asp-action="RehberListesi">
                    <i class="fa-solid fa-shield-halved text-secondary"></i>
                    Rehberler
                </a>

                <a asp-controller="Admin" asp-action="BossListesi">
                    <i class="fa-solid fa-shield-halved text-secondary"></i>
                    Bosslar
                </a>

                <a asp-controller="Admin" asp-action="UyeListesi">
                    <i class="fa-solid fa-shield-halved text-secondary"></i>
                    Üyeler
                </a>

                <a asp-controller="Admin" asp-action="Add">
                    <i class="fa-solid fa-fire-burner" style="color: #8c7340;"></i>
                    Yeni Lokasyon
                </a>

                <a asp-controller="Admin" asp-action="RehberEkle">
                    <i class="fa-solid fa-fire-burner" style="color: #8c7340;"></i>
                    Yeni Rehber
                </a>

                <a asp-controller="Admin" asp-action="BossEkle">
                    <i class="fa-solid fa-fire-burner" style="color: #8c7340;"></i>
                    Yeni Boss
                </a>


                <a asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-door-open text-danger"></i>
                    Siteye Dön
                </a>

                <a asp-controller="Admin" asp-action="Index">
                    <i class="fa-solid fa-door-open text-danger"></i>
                    Girişe Dön
                </a>

            </nav>

        </aside>

        <div class="main-content">

            <header class="topbar">

                <div>
                    <h4>@ViewData["Title"]</h4>
                </div>

                <div class="admin-user">
                    <i class="fa-solid fa-skull"></i>
                    Ashen One (Admin)
                </div>

            </header>

            <main class="content-area">

                @RenderBody()

            </main>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>